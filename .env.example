DISCORD_TOKEN=your-bot-token
DISCORD_APP_ID=your-discord-application-id
DISCORD_CLIENT_ID=your-discord-application-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-public-domain/auth/callback
DASHBOARD_SECRET_KEY=replace-with-a-long-random-secret
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_BASE_URL=https://your-public-domain
DISCORD_INSTALL_PERMISSIONS=8

# Railway injects PORT automatically.
# Railway also provides RAILWAY_PUBLIC_DOMAIN after you generate a public domain.
# If DASHBOARD_BASE_URL is not set, the app will fall back to RAILWAY_PUBLIC_DOMAIN when available.
